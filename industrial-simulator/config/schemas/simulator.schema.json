{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/industrial-simulator.schema.json",
  "type": "object",
  "required": ["protocols", "devices"],
  "additionalProperties": false,
  "properties": {
    "simulator": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "updateIntervalMs": { "type": "integer", "minimum": 10 },
        "hotReload": { "type": "boolean" },
        "scriptGeneratorsEnabled": { "type": "boolean" },
        "healthPort": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "protocols": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "host": { "type": "string" },
          "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "byteOrder": { "enum": ["big-endian", "little-endian"] },
          "wordOrder": { "enum": ["big-endian", "little-endian"] }
        }
      }
    },
    "devices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["deviceId", "protocol", "parameters"],
        "additionalProperties": false,
        "properties": {
          "deviceId": { "type": "string", "minLength": 1 },
          "deviceType": { "type": "string" },
          "displayName": { "type": "string" },
          "updateIntervalMs": { "type": "integer", "minimum": 10 },
          "protocol": {
            "type": "object",
            "required": ["type", "serverId"],
            "additionalProperties": false,
            "properties": {
              "type": { "type": "string", "minLength": 1 },
              "serverId": { "type": "string", "minLength": 1 },
              "slaveId": { "type": "integer", "minimum": 1, "maximum": 247 }
            }
          },
          "faults": { "$ref": "#/$defs/faults" },
          "parameters": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["parameterId", "dataType", "generator"],
              "additionalProperties": false,
              "properties": {
                "parameterId": { "type": "string", "minLength": 1 },
                "displayName": { "type": "string" },
                "dataType": {
                  "enum": [
                    "int16",
                    "uint16",
                    "int32",
                    "uint32",
                    "int64",
                    "uint64",
                    "float32",
                    "float64",
                    "boolean",
                    "string"
                  ]
                },
                "unit": { "type": "string" },
                "generator": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": ["type", "value"],
                      "properties": { "type": { "const": "static" }, "value": {} },
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "required": ["type", "min", "max"],
                      "properties": {
                        "type": { "const": "random" },
                        "min": { "type": "number" },
                        "max": { "type": "number" }
                      },
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "required": ["type", "min", "max", "step"],
                      "properties": {
                        "type": { "const": "linear-ramp" },
                        "min": { "type": "number" },
                        "max": { "type": "number" },
                        "step": { "type": "number" }
                      },
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "required": ["type", "amplitude", "offset", "periodSeconds"],
                      "properties": {
                        "type": { "const": "sine-wave" },
                        "amplitude": { "type": "number" },
                        "offset": { "type": "number" },
                        "periodSeconds": { "type": "number", "exclusiveMinimum": 0 }
                      },
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "required": ["type"],
                      "properties": {
                        "type": { "const": "sawtooth" },
                        "min": { "type": "number" },
                        "max": { "type": "number" },
                        "periodSeconds": { "type": "number", "exclusiveMinimum": 0 }
                      },
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "required": ["type"],
                      "properties": {
                        "type": { "const": "square-wave" },
                        "low": { "type": "number" },
                        "high": { "type": "number" },
                        "periodSeconds": { "type": "number", "exclusiveMinimum": 0 }
                      },
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "required": ["type", "sourceFile"],
                      "properties": {
                        "type": { "const": "replay" },
                        "sourceFile": { "type": "string" },
                        "parameterColumn": { "type": "string" },
                        "timestampColumn": { "type": "string" },
                        "loop": { "type": "boolean" }
                      },
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "required": ["type", "script"],
                      "properties": {
                        "type": { "const": "script" },
                        "script": { "type": "string" },
                        "initialValue": { "type": "number" }
                      },
                      "additionalProperties": false
                    }
                  ]
                },
                "mapping": {
                  "type": "object",
                  "required": ["registerType", "address"],
                  "additionalProperties": false,
                  "properties": {
                    "registerType": {
                      "enum": ["holding-register", "input-register", "coil", "discrete-input"]
                    },
                    "address": { "type": "integer", "minimum": 0 },
                    "length": { "type": "integer", "minimum": 1 }
                  }
                },
                "faults": { "$ref": "#/$defs/faults" }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "faults": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "enum": ["freeze", "timeout", "drift", "spike", "noise", "offline"] },
          "enabled": { "type": "boolean" },
          "ratePerTick": { "type": "number" },
          "value": { "type": "number" },
          "probability": { "type": "number", "minimum": 0, "maximum": 1 },
          "amplitude": { "type": "number" }
        },
        "additionalProperties": false
      }
    }
  }
}
